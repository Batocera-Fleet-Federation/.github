<mxfile host="app.diagrams.net" type="device">
  <diagram id="ee_false_arch" name="Architecture — enable_edge=false">
    <mxGraphModel dx="1024" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Batocera Swarm — enable_edge = FALSE  (no Edge deployed)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1000" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Drones use Overmind for coordination ONLY (outbound HTTPS). ROM/BIOS/save bytes move Drone&#8596;Drone directly. The TransportSelector has just two tiers — [ LAN-direct &#8594; direct-public ]. The relay and hole-punch tiers need the Edge, so they are absent here. Result: full P2P on the SAME LAN; cross-network P2P only to a port-forwarded drone." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=13;spacingLeft=8;spacingTop=6;size=18;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1520" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cp" value="CONTROL PLANE — Overmind (FastAPI · uvicorn/EC2 or AWS Lambda) — never carries ROM bytes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="430" y="150" width="740" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cp1" value="Auth · RBAC · Registration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="192" width="200" height="48" as="geometry" />
        </mxCell>
        <mxCell id="cp2" value="CA · mTLS cert signing&#10;(peer cert pinning)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="670" y="192" width="200" height="48" as="geometry" />
        </mxCell>
        <mxCell id="cp3" value="Peer metadata&#10;public_ip · local_ip · port" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="890" y="192" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="cp4" value="public-reachability probe — AUTO-ON when no Edge&#10;(TCP-probes each drone's public IP:port; sets reachable_url)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="262" width="480" height="56" as="geometry" />
        </mxCell>

        <mxCell id="natA" value="HOME NETWORK A — behind NAT A · single public IP 203.0.113.10" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="600" height="340" as="geometry" />
        </mxCell>
        <mxCell id="dA" value="Drone A — RECEIVER&#10;&#10;TransportSelector.fetch:&#10;  1) LAN-direct&#10;  2) direct-public&#10;(one active download · resume · hash verify)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="dB" value="Drone B — SOURCE&#10;&#10;serves GET /peer/{roms,bios,saves}&#10;mTLS · path-traversal-safe&#10;(same LAN as A)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="560" width="240" height="200" as="geometry" />
        </mxCell>

        <mxCell id="natB" value="HOME NETWORK B — behind NAT B · public IP 198.51.100.20" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="470" width="600" height="340" as="geometry" />
        </mxCell>
        <mxCell id="dC" value="Drone C — SOURCE (different network)&#10;&#10;serves /peer/* (mTLS)&#10;&#10;Reachable from the WAN ONLY if the&#10;router PORT-FORWARDS :443 &#8594; C." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="560" width="320" height="200" as="geometry" />
        </mxCell>

        <mxCell id="e_a_cp" value="outbound HTTPS&#10;heartbeat · claim actions · peer list · CSR sign" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;fontSize=11;endArrow=block;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="dA" target="cp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_c_cp" value="outbound HTTPS&#10;(coordination only)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;fontSize=11;endArrow=block;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="dC" target="cp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_probe" value="reachability probe &#8594; TCP 198.51.100.20:443&#10;succeeds ONLY if port-forwarded" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;dashed=1;strokeWidth=2;fontSize=11;endArrow=block;" edge="1" parent="1" source="cp4" target="dC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lan" value="LAN-direct  &#10003;&#10;mTLS GET &#8594; B.local_ip /peer/*&#10;same public_ip &#8658; same LAN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=3;fontSize=11;endArrow=block;startArrow=block;" edge="1" parent="1" source="dA" target="dB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_wan" value="direct-public — mTLS &#8594; C's public IP&#10;&#10003; ONLY if C port-forwarded&#10;&#10007; otherwise — NO relay fallback (transfer fails)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;dashed=1;strokeWidth=3;fontSize=11;endArrow=block;startArrow=block;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="dA" target="dC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="LEGEND&#10;&#10;&#9472;&#9472; blue  = control-plane HTTPS (coordination; no ROM bytes)&#10;&#9472;&#9472; green (thick) = working P2P data path (mTLS /peer/*)&#10;&#9472;&#9472; red dashed = path that works ONLY with port-forwarding&#10;yellow box = the auto-on reachability probe" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=12;spacingLeft=8;spacingTop=6;size=16;" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="560" height="170" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="WHEN enable_edge = FALSE FITS&#10;&#10;• All drones on ONE LAN  &#8594;  full P2P, free, no Edge, no router config.&#10;• Multi-site  &#8594;  only PORT-FORWARDED drones are reachable across the WAN&#10;   (the legacy model). Non-forwarded remote drones cannot sync.&#10;&#10;For no-router-config cross-network sync, set enable_edge = true&#10;(see the enable_edge_true diagram)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=12;spacingLeft=8;spacingTop=6;size=16;" vertex="1" parent="1">
          <mxGeometry x="700" y="850" width="600" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="ee_false_seq" name="Transfer sequence — enable_edge=false">
    <mxGraphModel dx="1024" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="s_title" value="Transfer sequence — Drone A wants ROM X  (enable_edge = false)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="32" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="1.  Drone A registers + heartbeats to Overmind (outbound HTTPS). Overmind returns the swarm peer list, each peer with public_ip + local_ip + port. (No persistent connection — this is poll-based.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1140" height="64" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2.  A needs ROM X. DownloadManager queues it (one active download) and calls TransportSelector.fetch(request). Tiers are tried best-first with fall-through: [ LAN-direct &#8594; direct-public ]." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="1140" height="64" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="3.  TIER 1 — LanDirectTransport.usable( peer )?   Is the peer's public_ip == A's own public_ip (from _build_local_ip_addresses — a local probe, NOT the Edge)?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="1140" height="58" as="geometry" />
        </mxCell>

        <mxCell id="s3b" value="3a.  PEER B — same public_ip (same NAT) &#8658; LAN-direct USABLE.&#10;&#8594; GET https://B.local_ip/peer/roms/&#8230;  (mTLS, cert-pinned)&#10;&#8594; stream chunks · resume on Range · verify fingerprint/MD5.&#10;&#10003;  DONE — bytes never touched Overmind." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="560" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s3c" value="3b.  PEER C — different public_ip &#8658; LAN-direct NOT usable.&#10;&#8594; fall through to Tier 2." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="360" width="540" height="150" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="4.  TIER 2 — DirectPublicTransport.fetch (peer C):&#10;&#8594; GET https://198.51.100.20:443/peer/roms/&#8230;  (mTLS to C's public IP / reachable_url from the probe)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="680" y="540" width="540" height="86" as="geometry" />
        </mxCell>
        <mxCell id="s5ok" value="4a.  C IS port-forwarded (probe set reachable_url)&#10;&#8594; stream + verify.  &#10003;  DONE (direct WAN)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="660" width="540" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s5no" value="4b.  C is NOT port-forwarded&#10;&#8594; connection refused / timeout. No more tiers (relay + hole-punch need the Edge).&#10;&#10007;  TRANSFER FAILS for this cross-network peer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="770" width="540" height="100" as="geometry" />
        </mxCell>

        <mxCell id="se1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3b" value="same LAN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="s3" target="s3b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3c" value="different network" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="s3" target="s3c"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#d79b00;" edge="1" parent="1" source="s3c" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se5ok" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;" edge="1" parent="1" source="s4" target="s5ok"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se5no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;" edge="1" parent="1" source="s5ok" target="s5no"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
