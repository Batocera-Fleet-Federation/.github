<mxfile host="app.diagrams.net" type="device">
  <diagram id="ee_true_arch" name="Architecture — Edge ON (hole-punch + relay)">
    <mxGraphModel background="#ffffff" dx="1024" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="1260" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Batocera Swarm — enable_edge = TRUE  (Edge deployed)" style="fontColor=#000000;text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every Drone holds ONE persistent OUTBOUND mux to the always-on Edge — no inbound ports, no port-forward, no public IP. The control plane only authorizes transfers (mints a short-lived token). ROM bytes move Drone&#8596;Drone over the best tier with fall-through: LAN-direct &#8594; direct-public &#8594; UDP hole-punch &#8594; Edge RELAY (last resort). The Edge relays opaque DATA only when direct fails, and never carries bytes on the other tiers or through the control plane. reachability probe AUTO-OFF." style="fontColor=#000000;shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=13;spacingLeft=8;spacingTop=6;size=18;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1680" height="66" as="geometry" />
        </mxCell>

        <mxCell id="cp" value="CONTROL PLANE — Overmind (FastAPI · uvicorn/EC2 or AWS Lambda) — authorize only, never carries ROM bytes" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="680" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cp1" value="Auth · RBAC · Registration · CA / mTLS cert signing" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="192" width="300" height="48" as="geometry" />
        </mxCell>
        <mxCell id="cp2" value="Transfer-token MINT&#10;POST /api/devices/{id}/transfers&#10;HMAC-SHA256 {sid,from,to,asset,exp}" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="186" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cp3" value="public-reachability probe — AUTO-OFF&#10;(OVERMIND_EDGE_ENABLED set; the Edge handles WAN)" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="262" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cp4" value="Monitoring&#10;GET /api/admin/transfers&#10;Super-Admin &#8220;Peer Transfers&#8221; panel" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="262" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge" value="EDGE — always-on  (ECS Fargate behind a Network Load Balancer · or self-hosted bff-edge container)" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5ec;strokeColor=#d79b00;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="150" width="880" height="230" as="geometry" />
        </mxCell>
        <mxCell id="nlb" value="NLB&#10;TLS :443&#10;&#8594; task :9443" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="200" width="120" height="150" as="geometry" />
        </mxCell>
        <mxCell id="mux" value="MuxServer (asyncio TLS)&#10;HELLO auth (verify_drone_token) · presence registry (edge_online)&#10;PING/PONG · device&#8594;connection map&#10;pushes TRANSFER_OFFER to the sender" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="985" y="196" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="stun" value="Signaling + STUN reflector&#10;reports each drone's reflexive (NAT) addr&#10;relays SIGNAL candidate exchange" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="985" y="286" width="380" height="74" as="geometry" />
        </mxCell>
        <mxCell id="relay" value="RelayHub (last resort)&#10;pairs sender+receiver legs by session_id&#10;forwards opaque DATA frames&#10;per-session bandwidth limit&#10;marks transfer_sessions:&#10;active &#8594; completed / aborted" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1385" y="196" width="295" height="164" as="geometry" />
        </mxCell>

        <mxCell id="rds" value="RDS Postgres&#10;transfer_sessions&#10;drone_network_state&#10;(edge_online, reflexive)" style="fontColor=#000000;shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;boundedLbl=1;backgroundOutline=1;size=14;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="420" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="ElastiCache Redis&#10;(cache · optional)" style="fontColor=#000000;shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;boundedLbl=1;backgroundOutline=1;size=14;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="430" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="natA" value="HOME NETWORK A — behind NAT A (public IP 203.0.113.10) · no inbound ports" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="620" height="420" as="geometry" />
        </mxCell>
        <mxCell id="dA" value="Drone A — RECEIVER&#10;&#10;persistent outbound mux &#8594; Edge&#10;&#10;TransportSelector.fetch:&#10;  1) LAN-direct&#10;  2) direct-public&#10;  3) hole-punch (UDP + reliable-ARQ)&#10;  4) Edge relay&#10;&#10;one active dl · progress · cancel&#10;resume · hash verify" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="90" y="710" width="270" height="300" as="geometry" />
        </mxCell>
        <mxCell id="dB" value="Drone B — SOURCE (same LAN as A)&#10;&#10;persistent outbound mux &#8594; Edge&#10;&#10;serves GET /peer/* (mTLS)&#10;serves relay via serve_asset()" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="710" width="260" height="300" as="geometry" />
        </mxCell>

        <mxCell id="natB" value="HOME NETWORK B — behind NAT B (public IP 198.51.100.20) · no inbound ports / no port-forward" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="620" width="620" height="420" as="geometry" />
        </mxCell>
        <mxCell id="dC" value="Drone C — SOURCE (different network)&#10;&#10;persistent outbound mux &#8594; Edge&#10;NO inbound ports, NO port-forward&#10;&#10;serves relay via serve_asset()&#10;hole-punch candidate via STUN" style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1330" y="710" width="320" height="300" as="geometry" />
        </mxCell>

        <mxCell id="e_a_mux" value="persistent outbound mux (TLS)&#10;HELLO/ACK · presence · PING · TRANSFER_REQUEST · SIGNAL · RELAY_*" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=2;fontSize=11;endArrow=block;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dA" target="nlb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_b_mux" value="outbound mux (TLS)" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=2;fontSize=11;endArrow=block;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="dB" target="nlb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_c_mux" value="outbound mux (TLS)" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=2;fontSize=11;endArrow=block;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dC" target="mux">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_a_cp" value="HTTPS&#10;register · POST /transfers &#8594; signed token" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;fontSize=11;endArrow=block;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.3;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="dA" target="cp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_edge_rds" value="presence + transfer_sessions&#10;(off-loop · best-effort)" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1" source="mux" target="rds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cp_rds" value="device records · session row" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1" source="cp" target="rds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_lan" value="TIER 1 — LAN-direct  &#10003;&#10;mTLS /peer/* to B.local_ip (same LAN) — Edge NOT used for bytes" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=3;fontSize=11;endArrow=block;startArrow=block;" edge="1" parent="1" source="dA" target="dB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_hp" value="TIER 3 — hole-punched UDP (reliable-ARQ)&#10;DIRECT Drone&#8596;Drone · bytes do NOT touch the Edge" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=3;dashed=1;fontSize=11;endArrow=block;startArrow=block;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="dA" target="dC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_relay_a" value="TIER 4 — relay leg&#10;(RELAY_OPEN/DATA over mux)" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=3;fontSize=11;endArrow=block;startArrow=block;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="dA" target="relay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_relay_c" value="relay leg&#10;(last resort)" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;strokeWidth=3;fontSize=11;endArrow=block;startArrow=block;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="dC" target="relay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="LEGEND&#10;&#10;&#9472;&#9472; orange = persistent outbound mux / Edge relay leg&#10;&#9472;&#9472; blue = control-plane HTTPS (authorize / mint token)&#10;&#9472;&#9472; green (thick) = direct P2P data path (LAN or hole-punch) — Edge carries NO bytes&#10;&#9472;&#9472; purple dashed = lean DB writes (presence · transfer_sessions)&#10;Tiers are tried best-first: LAN &#8594; direct-public &#8594; hole-punch &#8594; relay (fall-through on failure)." style="fontColor=#000000;shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=12;spacingLeft=8;spacingTop=6;size=16;" vertex="1" parent="1">
          <mxGeometry x="700" y="600" width="640" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="ee_true_seq" name="Transfer sequence — Edge ON (hole-punch + relay)">
    <mxGraphModel background="#ffffff" dx="1024" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="1640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t_title" value="Transfer sequence — Drone A pulls ROM X from Drone C (different network)  ·  enable_edge = true" style="fontColor=#000000;text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1280" height="32" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="1.  BOOT — A, B and C each open ONE persistent OUTBOUND mux to the Edge (connect_tls &#8594; HELLO &#8594; HELLO_ACK with their reflexive NAT address). The Edge marks each edge_online and writes presence to RDS. Drones also register/heartbeat to Overmind over HTTPS." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="2.  AUTHORIZE — A &#8594; Overmind: POST /api/devices/{A}/transfers { source=C, asset=ROM X }. Overmind checks RBAC + same-swarm, MINTS a short-lived HMAC token { sid, from=C, to=A, asset, exp } and writes a transfer_sessions row (status = offered)." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="1200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="3.  REQUEST — A &#8594; Edge (over its mux): TRANSFER_REQUEST { session_id, token, from=C, asset }." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="1200" height="52" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="4.  OFFER — Edge validates the token OFFLINE (shared SECRET_KEY), looks up C's live mux connection, and pushes TRANSFER_OFFER to C. No drone exposed a port; both sides were reached over their own outbound connections." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="332" width="1200" height="68" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="5.  TIER SELECTION — A &amp; C try transports best-first (fall through on failure):&#10;   • LAN-direct?  C.public_ip &#8800; A.public_ip  &#8594; not usable.&#10;   • direct-public?  C is not port-forwarded  &#8594; not usable.&#10;   • hole-punch &amp; relay below." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="1200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="t6a" value="6a.  TIER 3 — HOLE-PUNCH (preferred)&#10;A &amp; C exchange reflexive candidates via Edge SIGNAL (each learned its public ip:port from the STUN reflector). Mutual-confirm UDP punch. On success a reliable-UDP (windowed-ARQ) channel opens.&#10;&#8594; assetfetch FETCH / CHUNK / DONE runs DIRECT A&#8596;C — bytes do NOT touch the Edge. Resume + hash verify.&#10;&#10003;  Edge marks session active &#8594; completed." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="590" height="200" as="geometry" />
        </mxCell>
        <mxCell id="t6b" value="6b.  TIER 4 — EDGE RELAY (fallback, if punch fails)&#10;A and C each send RELAY_OPEN; the Edge RelayHub pairs the two legs and sends RELAY_READY. A runs assetfetch over the RelayChannel; the Edge FORWARDS opaque DATA frames between the two TLS legs (per-session bandwidth limit). The Edge cannot read the bytes on the other tiers; relay legs are TLS to the Edge.&#10;&#10003;  Edge marks session active &#8594; completed (or aborted on drop)." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="690" y="560" width="590" height="200" as="geometry" />
        </mxCell>

        <mxCell id="t7" value="7.  SAME-LAN SHORTCUT — if A instead pulls from B (same LAN), the selector picks TIER 1 LAN-direct immediately: mTLS GET /peer/* to B.local_ip. The Edge is used for presence/coordination but carries NO bytes." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="800" width="1200" height="64" as="geometry" />
        </mxCell>
        <mxCell id="t8" value="8.  OBSERVABILITY — the transfer_sessions lifecycle (offered &#8594; active &#8594; completed / aborted) is visible at GET /api/admin/transfers and the Super-Admin &#8220;Peer Transfers&#8221; panel, showing the transport used. The device-status job expires stale rows." style="fontColor=#000000;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="894" width="1200" height="64" as="geometry" />
        </mxCell>

        <mxCell id="te1" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t1" target="t2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te2" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t2" target="t3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te3" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t3" target="t4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te4" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t4" target="t5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te5a" value="punch OK" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="t5" target="t6a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te5b" value="punch fails &#8594; relay" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="t5" target="t6b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te6" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t6a" target="t7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="te7" style="fontColor=#000000;edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="t7" target="t8"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
